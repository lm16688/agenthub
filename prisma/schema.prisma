// AgentHub - AI Agent社交平台 数据库Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// 用户表
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String?
  avatar        String?
  bio           String?
  website       String?
  location      String?
  isPro         Boolean   @default(false)
  proExpiresAt  DateTime?
  emailVerified DateTime?
  image         String?
  role          String    @default("user")

  // 统计
  agentCount    Int       @default(0)
  skillCount    Int       @default(0)
  totalViews    Int       @default(0)
  totalLikes    Int       @default(0)

  // 关系
  agents        Agent[]
  skills        Skill[]
  reviews       Review[]
  accounts      Account[]
  sessions      Session[]
  agentLikes    Like[] @relation("AgentLikes")
  bookmarks     Bookmark[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Agent表
model Agent {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String
  prompt        String
  version       String    @default("1.0.0")
  isPublic      Boolean   @default(true)
  isFeatured    Boolean   @default(false)

  // 分类
  category      String
  tags          String

  // 统计
  views         Int       @default(0)
  likes         Int       @default(0)
  installs      Int       @default(0)
  comments      Int       @default(0)

  // 作者
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // 关系
  skills        Skill[]
  reviews       Review[]
  agentLikes    Like[] @relation("AgentLikes")
  bookmarks     Bookmark[]
  versions      AgentVersion[]

  // SEO
  ogImage       String?
  ogTitle       String?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Agent版本表（用于版本管理）
model AgentVersion {
  id            String    @id @default(cuid())
  version       String
  prompt        String
  changelog     String?

  agentId       String
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
}

// 技能表
model Skill {
  id            String    @id @default(cuid())
  name          String
  slug          String    @unique
  description   String
  version       String    @default("1.0.0")
  price         Int?      // 价格(分)，null表示免费，900=9元
  isPublic      Boolean   @default(true)

  // 分类
  category      String
  tags          String

  // 统计
  downloads     Int       @default(0)
  rating        Float     @default(0)
  reviewCount   Int       @default(0)
  likesCount    Int       @default(0)

  // 安装配置
  installConfig  String?   // 安装配置信息(JSON字符串)

  // 作者
  authorId      String
  author        User      @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // 适用于哪些agent
  agents        Agent[]
  reviews       Review[]
  bookmarks     Bookmark[]
  likes         Like[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// 评论/评价表
model Review {
  id            String    @id @default(cuid())
  rating        Int       // 1-5
  comment       String?

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  agentId       String?
  agent         Agent?    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  skillId       String?
  skill         Skill?    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([agentId])
  @@index([skillId])
}

// 点赞表
model Like {
  id            String    @id @default(cuid())

  userId        String
  user          User      @relation("AgentLikes", fields: [userId], references: [id], onDelete: Cascade)

  agentId       String?
  agent         Agent?    @relation("AgentLikes", fields: [agentId], references: [id], onDelete: Cascade)

  skillId       String?
  skill         Skill?    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())

  @@index([agentId])
  @@index([skillId])
}

// 收藏表
model Bookmark {
  id            String    @id @default(cuid())

  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  agentId       String?
  agent         Agent?    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  skillId       String?
  skill         Skill?    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  createdAt     DateTime  @default(now())

  @@index([agentId])
  @@index([skillId])
}

// NextAuth.js Account表
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

// NextAuth.js Session表
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// NextAuth.js VerificationToken表
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
